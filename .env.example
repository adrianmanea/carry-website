# Postgres connection string
DATABASE_URL=postgres://user@127.0.0.1:5432/carry_website

# Used to encrypt JWT tokens (generate with: openssl rand -hex 16)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs (generate with: openssl rand -hex 16)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests (generate with: openssl rand -hex 16)
PREVIEW_SECRET=YOUR_SECRET_HERE

# Media storage. Leave UNSET locally (uploads go to disk).
# In production (Vercel), the Blob integration sets this automatically and
# uploads are routed to Vercel Blob. See DEPLOYMENT.md.
# BLOB_READ_WRITE_TOKEN=
